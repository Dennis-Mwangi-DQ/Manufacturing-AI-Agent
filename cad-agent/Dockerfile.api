FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libfreetype6 \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# STEP/IGES support: pythonocc-core is conda-only and cannot be pip-installed.
# To enable real STEP/IGES parsing in this image, switch the base image to a
# conda distribution and install the package, e.g.:
#   FROM continuumio/miniconda3
#   RUN conda install -y -c conda-forge pythonocc-core
# Without it, the API still serves DXF flat patterns fully; STEP/IGES uploads
# return a clear error instead of fabricated geometry.

COPY app/ ./app/
COPY data/ ./data/

RUN mkdir -p /app/outputs /app/logs

ENV OUTPUT_DIR=/app/outputs
ENV PYTHONUNBUFFERED=1

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health')" || exit 1

CMD ["uvicorn", "app.api:app", "--host", "0.0.0.0", "--port", "8000"]
